# LOCAL target — the Groq fallback the local container uses.
# Source the repo's .env FIRST (for GROQ_API_KEY), then this file:
#   set -a; . ./.env; set +a; . security/targets/local.env
export TARGET_LABEL="local-groq"
export TARGET_BASE_URL="https://api.groq.com/openai/v1"
export TARGET_MODEL="llama-3.1-8b-instant"
export TARGET_API_KEY="${GROQ_API_KEY:?source ./.env first so GROQ_API_KEY is set}"
