# CLOUD target — the GKE vLLM router (Qwen2.5-3B).
# Reach it either way:
#   • port-forward:  kubectl port-forward svc/vllm-router-service 8000:80 -n default
#   • real ingress:  export CLOUD_BASE_URL=https://<your-router-host>/v1
export TARGET_LABEL="cloud-vllm"
export TARGET_BASE_URL="${CLOUD_BASE_URL:-http://localhost:8000/v1}"
export TARGET_MODEL="Qwen/Qwen2.5-3B-Instruct"
export TARGET_API_KEY="dummy"   # vLLM ignores it
